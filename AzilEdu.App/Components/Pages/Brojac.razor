@page "/brojac"
@rendermode InteractiveServer
 
<h1>Brojač klikova</h1>
 
<p>Trenutna vrijednost: @brojKlikova</p>
 
<button class="btn btn-primary" @onclick="PovecajBrojac">+</button>
<button class="btn btn-secondary" @onclick="SmanjiBrojac">-</button>
 
@code {
    int brojKlikova = 0;
 
    void PovecajBrojac()
    {
        brojKlikova++;
    }

    void SmanjiBrojac()
    {
        brojKlikova--;
    }
}
