@page "/animals"
@rendermode InteractiveServer
@using AzilEdu.Shared.Models
 
<PageTitle>Životinje</PageTitle>
 
<MudText Typo="Typo.h4" Class="mb-2">Popis životinja</MudText>
<MudText Typo="Typo.body1" Class="mb-4">
    Ovdje se prikazuje pregled životinja koje se trenutačno nalaze u azilu.
</MudText>
 
<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Ukupno životinja</MudText>
            <MudText Typo="Typo.h5">@TotalAnimals</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">U azilu</MudText>
            <MudText Typo="Typo.h5">@AnimalsInShelter</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">Udomljene</MudText>
            <MudText Typo="Typo.h5">@AdoptedAnimals</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">🐶 Pasa</MudText>
            <MudText Typo="Typo.h5">@DogCount</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.subtitle2">🐱 Mačaka</MudText>
            <MudText Typo="Typo.h5">@CatCount</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
 
<MudText Typo="Typo.subtitle1" Class="mb-1">Filter po statusu:</MudText>
<MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Class="mb-4">
    <MudButton OnClick="@ShowAllAnimals">Sve</MudButton>
    <MudButton OnClick="@ShowAnimalsInShelter">U azilu</MudButton>
    <MudButton OnClick="@ShowAdoptedAnimals">Udomljene</MudButton>
</MudButtonGroup>

<MudText Typo="Typo.subtitle1" Class="mb-1">Filter po vrsti:</MudText>
<MudButtonGroup Color="Color.Secondary" Variant="Variant.Outlined" Class="mb-4">
    <MudButton OnClick="@(() => FilterBySpecies("Sve"))">Sve vrste</MudButton>
    <MudButton OnClick="@(() => FilterBySpecies("Pas"))">Psi</MudButton>
    <MudButton OnClick="@(() => FilterBySpecies("Mačka"))">Mačke</MudButton>
</MudButtonGroup>
 
<MudTable Items="@FilteredAnimals" Hover="true" Striped="true" Bordered="true" Dense="true">
    <HeaderContent>
        <MudTh>Slika</MudTh>
        <MudTh>Ime</MudTh>
        <MudTh>Vrsta</MudTh>
        <MudTh>Pasmina</MudTh>
        <MudTh>Spol</MudTh>
        <MudTh>Starost</MudTh>
        <MudTh>Datum dolaska</MudTh>
        <MudTh>Opis</MudTh>
        <MudTh>Status</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Slika">
            <MudAvatar Size="Size.Large">
                <MudImage Src="@context.ImageUrl" Alt="@context.Name" />
            </MudAvatar>
        </MudTd>
        <MudTd DataLabel="Ime">@context.Name</MudTd>
        <MudTd DataLabel="Vrsta">@context.Species</MudTd>
        <MudTd DataLabel="Pasmina">@context.Breed</MudTd>
        <MudTd DataLabel="Spol">@context.Gender</MudTd>
        <MudTd DataLabel="Starost">@GetAgeText(context)</MudTd>
        <MudTd DataLabel="Datum dolaska">@GetArrivalDateText(context)</MudTd>
        <MudTd DataLabel="Opis">@GetShortDescription(context)</MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="@(context.IsAdopted ? Color.Success : Color.Warning)"
                     Variant="Variant.Filled">
                @GetAdoptionStatusText(context)
            </MudChip>
        </MudTd>
    </RowTemplate>
</MudTable>
 
@code {
    private string selectedStatus = "Sve";
    private string selectedSpecies = "Sve";
 
    private List<Animal> animals = new()
    {
        new Animal
        {
            Id = 1,
            Name = "Luna",
            Species = "Pas",
            Breed = "Labrador",
            Gender = "Ženka",
            Age = 3,
            ArrivalDate = new DateTime(2025, 10, 12),
            IsAdopted = false,
            ImageUrl = "/images/animals/luna.webp",
            Description = "Mirna i druželjubiva kujica koja voli šetnje."
        },
        new Animal
        {
            Id = 2,
            Name = "Maza",
            Species = "Mačka",
            Breed = "Domaća kratkodlaka",
            Gender = "Ženka",
            Age = 2,
            ArrivalDate = new DateTime(2025, 11, 5),
            IsAdopted = true,
            ImageUrl = "/images/animals/maza.webp",
            Description = "Zaigrana mačka naviknuta na boravak u zatvorenom prostoru."
        },
        new Animal
        {
            Id = 3,
            Name = "Rex",
            Species = "Pas",
            Breed = "Njemački ovčar",
            Gender = "Mužjak",
            Age = 5,
            ArrivalDate = new DateTime(2026, 1, 20),
            IsAdopted = false,
            ImageUrl = "/images/animals/rex.webp",
            Description = "Aktivan pas koji traži iskusnijeg vlasnika."
        },
        new Animal
        {
            Id = 4,
            Name = "Nala",
            Species = "Mačka",
            Breed = "Maine Coon mješanac",
            Gender = "Ženka",
            Age = null,
            ArrivalDate = new DateTime(2026, 2, 3),
            IsAdopted = false,
            ImageUrl = "/images/animals/nala.webp",
            Description = "Mlada mačka pronađena bez poznate povijesti."
        },
        new Animal
        {
            Id = 5,
            Name = "Tobi",
            Species = "Pas",
            Breed = "Mješanac",
            Gender = "Mužjak",
            Age = 1,
            ArrivalDate = null,
            IsAdopted = false,
            ImageUrl = "/images/animals/tobi.webp",
            Description = "Vesel pas kojem datum dolaska još nije potvrđen."
        },
        new Animal
        {
            Id = 6,
            Name = "Bruno",
            Species = "Pas",
            Breed = "Bigl",
            Gender = "Mužjak",
            Age = 4,
            ArrivalDate = new DateTime(2025, 9, 18),
            IsAdopted = true,
            ImageUrl = "/images/animals/bruno.webp",
            Description = "Udomljen pas koji ostaje u evidenciji azila."
        },
        new Animal
        {
            Id = 7,
            Name = "Sjena",
            Species = "Mačka",
            Breed = "Nepoznata",
            Gender = "Nepoznato",
            Age = null,
            ArrivalDate = null,
            IsAdopted = false,
            ImageUrl = "/images/animals/sjena.webp",
            Description = "Životinja s potpuno nepoznatom dobi i datumom dolaska, pronađena bez ikakvih podataka."
        }
    };
 
    private int TotalAnimals => animals.Count;
 
    private int AnimalsInShelter => animals.Count(animal => !animal.IsAdopted);
 
    private int AdoptedAnimals => animals.Count(animal => animal.IsAdopted);

    private int DogCount => animals.Count(animal => animal.Species == "Pas");

    private int CatCount => animals.Count(animal => animal.Species == "Mačka");
 
    private IEnumerable<Animal> FilteredAnimals =>
        animals
            .Where(animal => selectedStatus switch
            {
                "U azilu" => !animal.IsAdopted,
                "Udomljene" => animal.IsAdopted,
                _ => true
            })
            .Where(animal => selectedSpecies == "Sve" || animal.Species == selectedSpecies);
 
    private void ShowAllAnimals()
    {
        selectedStatus = "Sve";
    }
 
    private void ShowAnimalsInShelter()
    {
        selectedStatus = "U azilu";
    }
 
    private void ShowAdoptedAnimals()
    {
        selectedStatus = "Udomljene";
    }

    private void FilterBySpecies(string species)
    {
        selectedSpecies = species;
    }
 
    private string GetAgeText(Animal animal)
    {
        if (animal.Age.HasValue)
        {
            return $"{animal.Age.Value} god.";
        }
 
        return "Nepoznato";
    }
 
    private string GetArrivalDateText(Animal animal)
    {
        if (animal.ArrivalDate.HasValue)
        {
            return animal.ArrivalDate.Value.ToShortDateString();
        }
 
        return "Nije uneseno";
    }
 
    private string GetAdoptionStatusText(Animal animal)
    {
        if (animal.IsAdopted)
        {
            return "Udomljena";
        }
 
        return "U azilu";
    }

    private string GetShortDescription(Animal animal)
    {
        if (string.IsNullOrWhiteSpace(animal.Description))
            return string.Empty;

        var words = animal.Description.Split(' ');
        if (words.Length <= 5)
            return animal.Description;

        return string.Join(" ", words.Take(5)) + "...";
    }
}